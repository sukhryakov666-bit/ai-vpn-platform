{
  "id": null,
  "uid": "ai-vpn-observability",
  "title": "AI VPN Observability",
  "tags": ["ai-vpn", "loki", "request-id"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "request_id",
        "type": "textbox",
        "label": "Request ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API 5xx Count (5m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"api.http\"} | json | status=~\"5..\" [5m]))",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "401 Count (10m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"api.http\"} | json | status=\"401\" [10m]))",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Link Code Failures (10m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"admin-web.telegram\"} | json | event=\"link_code_issue_failed\" [10m]))",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "WireGuard Provision/Revoke Success (10m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"api.connectivity\"} | json | event=~\"wireguard_(provision|revoke)_success\" [10m]))",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "WireGuard Provision/Revoke Failures (10m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"api.connectivity\"} | json | event=~\"wireguard_(provision|revoke)_failed\" [10m]))",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Correlated Request Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "{request_id=~\"$request_id\"}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
