NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_vpn_platform?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ADMIN_EMAIL_ALLOWLIST=admin@ai-vpn.local
CORS_ORIGIN=http://localhost:3001
ENABLE_SWAGGER=true
TELEGRAM_INTERNAL_TOKEN=change-me-internal-token

TELEGRAM_BOT_TOKEN=change-me-telegram-token

ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=oncall@example.com
ALERT_SMARTHOST=smtp.example.com:587
ALERT_SMTP_USERNAME=alerts@example.com
ALERT_SMTP_PASSWORD=change-me-smtp-password
ALERT_TELEGRAM_BOT_TOKEN=change-me-alert-telegram-bot-token
ALERT_TELEGRAM_CHAT_ID=123456789
ALERT_PAGING_WEBHOOK_URL=https://events.example.com/v2/enqueue
ALERT_PAGERDUTY_ROUTING_KEY=change-me-pagerduty-routing-key
ALERT_OPSGENIE_API_KEY=change-me-opsgenie-api-key
